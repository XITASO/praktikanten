@page "/CreateLobby"

@using PlayTogether.Web.Services
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage

@inject LobbyService Lobby
@inject NavigationManager Navigation
@inject ProtectedLocalStorage ProtectedLocalStorage

<style>
    .create-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #1e5631 0%, #2e8b57 50%, #a8e063 100%);
        padding: 40px 20px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .create-card {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 24px;
        padding: 40px;
        max-width: 420px;
        width: 100%;
        box-shadow: 0 20px 50px rgba(0,0,0,0.35);
        border: 4px solid #a8e063;
        text-align: center;
    }

    .create-title {
        font-size: 2.2rem;
        font-weight: 800;
        color: #1e5631;
        margin-bottom: 8px;
    }

    .create-title::before {
        content: "🍉 ";
    }

    .player-tag {
        display: inline-block;
        background: #eaffea;
        color: #1e5631;
        font-weight: 600;
        padding: 6px 16px;
        border-radius: 50px;
        margin-bottom: 24px;
        font-size: 0.95rem;
    }

    .field-label {
        text-align: left;
        font-weight: 700;
        color: #1e5631;
        margin: 16px 0 6px 4px;
    }

    .funky-input {
        width: 100%;
        padding: 12px 16px;
        border-radius: 12px;
        border: 2px solid #a8e063;
        font-size: 1rem;
        box-sizing: border-box;
        transition: border-color 0.2s;
    }

    .funky-input:focus {
        outline: none;
        border-color: #2e8b57;
    }

    .funky-error {
        color: #d1495b;
        font-weight: 600;
        margin-top: 12px;
    }

    .btn-create {
        width: 100%;
        background: #2e8b57;
        color: white;
        border: none;
        border-radius: 14px;
        padding: 14px;
        font-size: 1.1rem;
        font-weight: 800;
        cursor: pointer;
        margin-top: 24px;
        box-shadow: 0 6px 0 #1e5631;
        transition: all 0.15s ease;
    }

    .btn-create:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 0 #1e5631;
    }

    .btn-create:active {
        transform: translateY(4px);
        box-shadow: 0 2px 0 #1e5631;
    }

    .back-link {
        display: inline-block;
        margin-top: 20px;
        color: #1e5631;
        font-weight: 600;
        text-decoration: none;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: #2e8b57;
        text-decoration: underline;
    }
</style>

<div class="create-page">
    <div class="create-card">

        <h1 class="create-title">Create Lobby</h1>
        <div class="player-tag">👤 @PlayerName</div>

        <p class="field-label">Lobby Name</p>
        <input type="text" class="funky-input" maxlength="15" @bind="lobbyname" />

        <p class="field-label">Lobby Code</p>
        <input type="text" class="funky-input" @bind="code" />

        @if (showError)
        {
            <p class="funky-error">@errorMessage</p>
        }

        <button class="btn-create" @onclick="Create">
            🚀 Create
        </button>

        <br />
        <a href="/LobbyList" class="back-link">← Bestehende Lobby beitreten</a>

    </div>
</div>

@code {
    string lobbyname = "";
    string code = "";
    bool showError = false;
    string errorMessage = "";

    private string PlayerName = "";
    
    private void Create()
    {
        if (string.IsNullOrWhiteSpace(lobbyname))
        {
            errorMessage = "Bitte einen Lobby-Namen eingeben!";
            showError = true;
            return;
        }

        if (lobbyname.Length > 15)
        {
            errorMessage = "Lobby-Name darf maximal 15 Zeichen lang sein!";
            showError = true;
            return;
        }

        showError = false;
        Lobby.CreateLobby(lobbyname, code);

        Navigation.NavigateTo("/LobbyList");
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var result = await ProtectedLocalStorage.GetAsync<string>("username");
            if (result.Success &&  result.Value != null)
            {
                PlayerName = result.Value;
                StateHasChanged();
            }
            else {
                Navigation.NavigateTo("/");
            }
        }
    }
    
}