@page "/"
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using Microsoft.AspNetCore.WebUtilities

@inject ProtectedLocalStorage ProtectedLocalStorage
@inject NavigationManager Navigation

<style>
    .home-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #1e5631 0%, #2e8b57 50%, #a8e063 100%);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .home-card {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 24px;
        padding: 48px 40px;
        max-width: 420px;
        width: 100%;
        text-align: center;
        box-shadow: 0 20px 50px rgba(0,0,0,0.35);
        border: 4px solid #a8e063;
        animation: popIn 0.3s ease;
    }

    @@keyframes popIn {
        from { transform: scale(0.85); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }

    .home-emoji {
        font-size: 4rem;
        margin-bottom: 8px;
    }

    .home-title {
        font-size: 2rem;
        font-weight: 800;
        color: #1e5631;
        margin-bottom: 8px;
    }

    .home-subtitle {
        color: #4a4a4a;
        font-weight: 500;
        margin-bottom: 28px;
    }

    .funky-input {
        width: 100%;
        padding: 14px 18px;
        border-radius: 14px;
        border: 2px solid #a8e063;
        font-size: 1.1rem;
        box-sizing: border-box;
        text-align: center;
        transition: border-color 0.2s;
    }

    .funky-input:focus {
        outline: none;
        border-color: #2e8b57;
    }

    .btn-start {
        width: 100%;
        background: #2e8b57;
        color: white;
        border: none;
        border-radius: 14px;
        padding: 16px;
        font-size: 1.2rem;
        font-weight: 800;
        cursor: pointer;
        margin-top: 24px;
        box-shadow: 0 6px 0 #1e5631;
        transition: all 0.15s ease;
    }

    .btn-start:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 0 #1e5631;
    }

    .btn-start:active {
        transform: translateY(4px);
        box-shadow: 0 2px 0 #1e5631;
    }
</style>

<div class="home-page">
    <div class="home-card">

        <div class="home-emoji">🍉</div>
        <h1 class="home-title">PlayTogether</h1>
        <p class="home-subtitle">Wie sollen wir dich nennen?</p>

        <input class="funky-input"
               placeholder="Spielername"
               @bind="PlayerName"
               @bind:event="oninput"
               @onkeydown="HandleKeyDown" />

        <button class="btn-start" @onclick="Start">
            🚀 Start
        </button>

    </div>
</div>


@code {

    private string PlayerName = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
            bool wantsChange = QueryHelpers.ParseQuery(uri.Query)
                .TryGetValue("change", out var value) && value == "true";

            if (wantsChange)
            {
                return; // bleibt auf "/", keine automatische Weiterleitung
            }

            var result = await ProtectedLocalStorage.GetAsync<string>("username");
            if (result.Success)
            {
                Navigation.NavigateTo("/LobbyList");
            }
        }
    }
    
    private async Task Start()
    {
        if (!string.IsNullOrWhiteSpace(PlayerName))
        {
            await ProtectedLocalStorage.SetAsync("username", PlayerName);
            Navigation.NavigateTo("/CreateLobby");
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Start();
        }
    }
}